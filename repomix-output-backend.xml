import { prisma } from "../../lib/prisma";
import { AppError } from "../../utils/AppError";

export type OnboardPayload = {
  studentId: string;
  faculty: string;
  department: string;
  program: string;
  batch: string;
  currentSemester: number;
  section: string;
};

type UpdateProfilePayload = {
  name?: string;
  phoneNumber?: string;
  bloodGroup?: any;
  batch?: string;
  currentSemester?: number;
  section?: string;
  skills?: string;
  linkedInUrl?: string;
  personalWebsiteUrl?: string;
};

export const onboardStudentService = async (
  userId: string,
  data: OnboardPayload,
) => {
  const existingProfile = await prisma.studentProfile.findUnique({
    where: { userId },
  });

  if (existingProfile) {
    throw new AppError("A student profile already exists for this user.", 409);
  }

  return await prisma.$transaction(async (tx) => {
    await tx.user.update({
      where: { id: userId },
      data: { role: "STUDENT" },
    });

    return await tx.studentProfile.create({
      data: {
        userId,
        studentId: data.studentId,
        faculty: data.faculty,
        department: data.department,
        program: data.program,
        batch: data.batch,
        currentSemester: data.currentSemester,
        section: data.section,
        isCR: false,
        isTA: false,
      },
    });
  });
};

export const updateProfileImageService = async (
  userId: string,
  imageUrl: string,
) => {
  return await prisma.user.update({
    where: { id: userId },
    data: { image: imageUrl },
    select: { id: true, name: true, image: true },
  });
};

export const getStudentProfileByUserId = async (userId: string) => {
  return await prisma.user.findUnique({
    where: { id: userId },
    select: {
      id: true,
      name: true,
      email: true,
      image: true,
      phoneNumber: true,
      bloodGroup: true,
      role: true,
      studentProfile: {
        select: {
          studentId: true,
          faculty: true,
          department: true,
          program: true,
          batch: true,
          currentSemester: true,
          section: true,
          isCR: true,
          isTA: true,
          skills: true,
          linkedInUrl: true,
          personalWebsiteUrl: true,
        },
      },
    },
  });
};

export const updateStudentProfileData = async (
  userId: string,
  data: UpdateProfilePayload,
) => {
  return await prisma.$transaction(async (tx) => {
    // 1. User table updates
    const userUpdateData: any = {};
    if (data.name) userUpdateData.name = data.name;
    if (data.phoneNumber !== undefined)
      userUpdateData.phoneNumber = data.phoneNumber;
    if (data.bloodGroup !== undefined)
      userUpdateData.bloodGroup = data.bloodGroup;

    if (Object.keys(userUpdateData).length > 0) {
      await tx.user.update({
        where: { id: userId },
        data: userUpdateData,
      });
    }

    // 2. StudentProfile table updates
    const profileUpdateData: any = {};
    if (data.batch) profileUpdateData.batch = data.batch;
    if (data.currentSemester)
      profileUpdateData.currentSemester = data.currentSemester;
    if (data.section !== undefined) profileUpdateData.section = data.section;
    if (data.skills !== undefined) profileUpdateData.skills = data.skills;
    if (data.linkedInUrl !== undefined)
      profileUpdateData.linkedInUrl = data.linkedInUrl;
    if (data.personalWebsiteUrl !== undefined)
      profileUpdateData.personalWebsiteUrl = data.personalWebsiteUrl;

    if (Object.keys(profileUpdateData).length > 0) {
      await tx.studentProfile.update({
        where: { userId: userId },
        data: profileUpdateData,
      });
    }

    // Return merged updated data
    return await getStudentProfileByUserId(userId);
  });
};
</file>

<file path="prisma/schema.prisma">
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==============================
// ENUMS
// ==============================

enum SystemRole {
  ADMIN
  STUDENT
  TEACHER
}

enum HubRole {
  TEACHER
  CR
  TA
  STUDENT
}

enum AssessmentType {
  ASSIGNMENT
  QUIZ
  PRESENTATION
}

enum SubmissionType {
  ONLINE
  HAND
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

// ==============================
// BETTER AUTH CORE SCHEMAS
// ==============================

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  emailVerified Boolean     @default(false)
  name          String
  image         String?
  role          SystemRole?
  phoneNumber   String?
  bloodGroup    BloodGroup?

  // Better Auth Relations
  sessions Session[]
  accounts Account[]

  // 1-to-1 Profiles
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?

  // App Relations
  hubs          HubMember[]
  resources     Resource[]
  createdTasks  Assessment[]   @relation("CreatedAssessments")
  submissions   Submission[]
  gradedWork    Submission[]   @relation("GradedSubmissions")
  helpPosts     HelpPost[]
  helpResponses HelpResponse[]
  bloodPosts    BloodPost[]
  reviews       CourseReview[]

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  bloodResponses       BloodResponse[]
  complaints           Complaint[]
  fieldBookings        FieldBooking[]
  hubAnnouncements     HubAnnouncement[]
  hubDiscussions       HubDiscussion[]
  hubDiscussionReplies HubDiscussionReply[]
  announcementComments AnnouncementComment[]

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String? // Hashed password for credentials provider
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ==============================
// ROLE-SPECIFIC PROFILES
// ==============================

model StudentProfile {
  id        String @id @default(uuid())
  userId    String @unique
  studentId String @unique

  faculty         String
  department      String
  program         String
  batch           String
  currentSemester Int
  section         String

  isCR Boolean @default(false)
  isTA Boolean @default(false)

  skills             String[]
  linkedInUrl        String?
  personalWebsiteUrl String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeacherProfile {
  id        String @id @default(uuid())
  userId    String @unique
  teacherId String @unique

  designation String
  department  String
  faculty     String

  officeRoom        String?
  consultationHours String?

  expertiseFields        String[]
  academicQualifications Json?

  linkedInUrl        String?
  personalWebsiteUrl String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==============================
// COURSE HUB MODULE
// ==============================

model CourseHub {
  id                  String  @id @default(uuid())
  courseCode          String
  courseName          String
  credit              Float
  termOffer           String
  weeklyClassSchedule Json
  termExams           Json? // 👈 NEW: Consolidated exam data
  joinCode            String  @unique
  isArchived          Boolean @default(false)
  department          String
  batch               String
  semesterNumber      Int

  isReviewOpen    Boolean @default(false)
  reviewQuestions Json?

  members       HubMember[]
  resources     Resource[]
  assessments   Assessment[]
  reviews       CourseReview[]
  announcements HubAnnouncement[]
  discussions   HubDiscussion[]

  createdAt DateTime @default(now())
}

model HubMember {
  id       String  @id @default(uuid())
  userId   String
  hubId    String
  role     HubRole
  isActive Boolean @default(true)

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hub  CourseHub @relation(fields: [hubId], references: [id], onDelete: Cascade)

  @@unique([userId, hubId])
}

// ==============================
// HUB ANNOUNCEMENTS & DISCUSSIONS
// ==============================

model HubAnnouncement {
  id                String   @id @default(uuid())
  hubId             String
  creatorId         String
  content           String
  attachedLinkUrl   String? // 👈 NEW
  attachedLinkTitle String? // 👈 NEW
  createdAt         DateTime @default(now())

  hub      CourseHub             @relation(fields: [hubId], references: [id], onDelete: Cascade)
  creator  User                  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  comments AnnouncementComment[] // 👈 NEW
}

model AnnouncementComment {
  id             String   @id @default(uuid())
  content        String
  announcementId String
  authorId       String
  createdAt      DateTime @default(now())

  announcement HubAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  author       User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model HubDiscussion {
  id        String   @id @default(uuid())
  hubId     String
  authorId  String
  title     String
  content   String
  createdAt DateTime @default(now())

  hub     CourseHub            @relation(fields: [hubId], references: [id], onDelete: Cascade)
  author  User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies HubDiscussionReply[]
}

model HubDiscussionReply {
  id           String   @id @default(uuid())
  discussionId String
  authorId     String
  content      String
  createdAt    DateTime @default(now())

  discussion HubDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ==============================
// ASSESSMENTS & GRADING
// ==============================

model Assessment {
  id             String          @id @default(uuid())
  hubId          String
  creatorId      String
  title          String
  description    String?
  type           AssessmentType
  submissionType SubmissionType?
  deadline       DateTime
  totalMarks     Float

  hub         CourseHub    @relation(fields: [hubId], references: [id], onDelete: Cascade)
  creator     User         @relation("CreatedAssessments", fields: [creatorId], references: [id])
  submissions Submission[]
  createdAt   DateTime     @default(now())
}

model Submission {
  id           String  @id @default(uuid())
  assessmentId String
  studentId    String
  submittedUrl String?
  marks        Float?
  gradedById   String?

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gradedBy   User?      @relation("GradedSubmissions", fields: [gradedById], references: [id])
  createdAt  DateTime   @default(now())

  @@unique([assessmentId, studentId])
}

// ==============================
// RESOURCES & DIGITAL VAULT
// ==============================

model Resource {
  id            String  @id @default(uuid())
  title         String
  driveUrl      String
  uploaderId    String
  hubId         String? // If Null -> Global Vault. If present -> Local Hub
  isStudentNote Boolean @default(false)
  rating        Float   @default(0) // Vault Promotion Threshold

  uploader  User       @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  hub       CourseHub? @relation(fields: [hubId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
}

// ==============================
// COMMUNITY & POSTS
// ==============================

model HelpPost {
  id          String         @id @default(uuid())
  authorId    String
  title       String
  description String
  isResolved  Boolean        @default(false)
  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  responses   HelpResponse[]
  createdAt   DateTime       @default(now())
}

model HelpResponse {
  id          String   @id @default(uuid())
  postId      String
  responderId String
  content     String
  post        HelpPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  responder   User     @relation(fields: [responderId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model BloodPost {
  id               String          @id @default(uuid())
  authorId         String
  patientName      String
  patientCondition String
  bloodGroup       BloodGroup
  location         String
  urgency          String
  contactPhone     String
  isFulfilled      Boolean         @default(false)
  author           User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  responses        BloodResponse[]
  createdAt        DateTime        @default(now())
}

model BloodResponse {
  id          String  @id @default(uuid())
  postId      String
  responderId String
  message     String? // Optional short message like "I am nearby and can come now"

  post      BloodPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  responder User      @relation(fields: [responderId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

// ==============================
// RATINGS & GLOBAL ADMIN
// ==============================

model CourseReview {
  id          String  @id @default(uuid())
  hubId       String
  studentId   String
  rating      Int
  comment     String?
  isAnonymous Boolean @default(true)
  answers     Json?

  hub       CourseHub @relation(fields: [hubId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([hubId, studentId]) // One review per student per hub
}

model BusSchedule {
  id            String   @id @default(uuid())
  route         String
  busNumber     String
  departureTime String
  stops         String[]
  createdAt     DateTime @default(now())
}

// ==============================
// ACADEMIC CALENDAR MODULE
// ==============================

model AcademicCalendar {
  id                String          @id @default(uuid())
  title             String
  semester          String
  isActive          Boolean         @default(true)
  isGlobal          Boolean         @default(false)
  targetFaculties   String[]
  targetDepartments String[]
  events            CalendarEvent[] // 👈 This connects the events
  createdAt         DateTime        @default(now())
}

model CalendarEvent {
  id          String           @id @default(uuid())
  calendarId  String
  calendar    AcademicCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  isHoliday   Boolean          @default(false)
  createdAt   DateTime         @default(now())
}

// ==============================
// GLOBAL NOTICEBOARD & EVENTS
// ==============================

model Notice {
  id                String   @id @default(uuid())
  referenceNo       String?
  title             String
  body              String
  issuerName        String
  issuerDesignation String
  copyTo            String[]

  issueDate DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CampusEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  location    String? // e.g., "Auditorium", "Permanent Campus Ground"
  eventDate   DateTime // Admin specified date and time

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==============================
// COMPLAINTS MANAGEMENT
// ==============================
enum ComplaintStatus {
  PENDING
  RESOLVED
  REJECTED
}

model Complaint {
  id          String          @id @default(uuid())
  userId      String
  title       String
  description String
  category    String // e.g., "Facilities", "Academic", "Hostel", "Other"
  status      ComplaintStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==============================
// ALUMNI DIRECTORY
// ==============================
model Alumni {
  id                 String   @id @default(uuid())
  name               String
  email              String?
  batch              String
  graduationYear     Int
  department         String
  degree             String?
  currentCompany     String?
  currentPosition    String?
  skills             String[]
  linkedInUrl        String?
  personalWebsiteUrl String?
  image              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==============================
// FIELD BOOKING
// ==============================
enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
}

model FieldBooking {
  id          String        @id @default(uuid())
  userId      String
  purpose     String // e.g., "CSE Dept Football Practice"
  bookingDate DateTime
  startTime   DateTime
  endTime     DateTime
  status      BookingStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// A single row table to control if the field is open or closed globally
model FieldSetting {
  id            String   @id @default(uuid())
  isBookingOpen Boolean  @default(true)
  closedNotice  String? // The notice shown when booking is disabled
  updatedAt     DateTime @updatedAt
}
</file>

