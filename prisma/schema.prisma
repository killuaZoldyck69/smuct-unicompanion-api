// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==============================
// ENUMS
// ==============================

enum SystemRole {
  ADMIN
  STUDENT
  TEACHER
}

enum HubRole {
  TEACHER
  CR
  TA
  STUDENT
}

enum AssessmentType {
  ASSIGNMENT
  QUIZ
}

enum SubmissionType {
  ONLINE
  HAND
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

// ==============================
// BETTER AUTH CORE SCHEMAS
// ==============================

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  emailVerified Boolean     @default(false)
  name          String
  image         String?
  role          SystemRole?
  phoneNumber   String?
  bloodGroup    BloodGroup?

  // Better Auth Relations
  sessions Session[]
  accounts Account[]

  // 1-to-1 Profiles
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?

  // App Relations
  hubs          HubMember[]
  resources     Resource[]
  createdTasks  Assessment[]   @relation("CreatedAssessments")
  submissions   Submission[]
  gradedWork    Submission[]   @relation("GradedSubmissions")
  helpPosts     HelpPost[]
  helpResponses HelpResponse[]
  bloodPosts    BloodPost[]
  reviews       CourseReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String? // Hashed password for credentials provider
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ==============================
// ROLE-SPECIFIC PROFILES
// ==============================

model StudentProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  studentId       String  @unique
  department      String
  batch           String
  currentSemester Int
  section         String?
  isCR            Boolean @default(false)
  isTA            Boolean @default(false)
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeacherProfile {
  id                String  @id @default(uuid())
  userId            String  @unique
  designation       String
  department        String
  officeRoom        String?
  consultationHours String?
  specialization    String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==============================
// COURSE HUB MODULE
// ==============================

model CourseHub {
  id                  String    @id @default(uuid())
  courseCode          String
  courseName          String
  credit              Float
  termOffer           String
  weeklyClassSchedule String
  classroomNumber     String?
  midtermExamDate     DateTime?
  finalExamDate       DateTime?
  joinCode            String    @unique
  isArchived          Boolean   @default(false)
  department          String
  batch               String
  semesterNumber      Int

  members     HubMember[]
  resources   Resource[]
  assessments Assessment[]
  reviews     CourseReview[]

  createdAt DateTime @default(now())
}

model HubMember {
  id       String  @id @default(uuid())
  userId   String
  hubId    String
  role     HubRole
  isActive Boolean @default(true) // Soft Archive

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hub  CourseHub @relation(fields: [hubId], references: [id], onDelete: Cascade)

  @@unique([userId, hubId])
}

// ==============================
// ASSESSMENTS & GRADING
// ==============================

model Assessment {
  id             String          @id @default(uuid())
  hubId          String
  creatorId      String
  title          String
  description    String?
  type           AssessmentType
  submissionType SubmissionType?
  deadline       DateTime

  hub         CourseHub    @relation(fields: [hubId], references: [id], onDelete: Cascade)
  creator     User         @relation("CreatedAssessments", fields: [creatorId], references: [id])
  submissions Submission[]
  createdAt   DateTime     @default(now())
}

model Submission {
  id           String  @id @default(uuid())
  assessmentId String
  studentId    String
  submittedUrl String?
  marks        Float?
  gradedById   String?

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gradedBy   User?      @relation("GradedSubmissions", fields: [gradedById], references: [id])
  createdAt  DateTime   @default(now())

  @@unique([assessmentId, studentId])
}

// ==============================
// RESOURCES & DIGITAL VAULT
// ==============================

model Resource {
  id            String  @id @default(uuid())
  title         String
  driveUrl      String
  uploaderId    String
  hubId         String? // If Null -> Global Vault. If present -> Local Hub
  isStudentNote Boolean @default(false)
  rating        Float   @default(0) // Vault Promotion Threshold

  uploader  User       @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  hub       CourseHub? @relation(fields: [hubId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
}

// ==============================
// COMMUNITY & POSTS
// ==============================

model HelpPost {
  id          String         @id @default(uuid())
  authorId    String
  title       String
  description String
  isResolved  Boolean        @default(false)
  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  responses   HelpResponse[]
  createdAt   DateTime       @default(now())
}

model HelpResponse {
  id          String   @id @default(uuid())
  postId      String
  responderId String
  content     String
  post        HelpPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  responder   User     @relation(fields: [responderId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model BloodPost {
  id           String     @id @default(uuid())
  authorId     String
  patientName  String
  bloodGroup   BloodGroup
  location     String
  urgency      String
  contactPhone String
  isFulfilled  Boolean    @default(false)
  author       User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

// ==============================
// RATINGS & GLOBAL ADMIN
// ==============================

model CourseReview {
  id          String  @id @default(uuid())
  hubId       String
  studentId   String
  rating      Int
  comment     String?
  isAnonymous Boolean @default(true)

  hub       CourseHub @relation(fields: [hubId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([hubId, studentId]) // One review per student per hub
}

model BusSchedule {
  id            String   @id @default(uuid())
  route         String
  busNumber     String
  departureTime String
  stops         String[]
  createdAt     DateTime @default(now())
}

model AcademicCalendar {
  id              String   @id @default(uuid())
  title           String
  facultyOrSchool String
  driveUrl        String
  createdAt       DateTime @default(now())
}

// ==============================
// GLOBAL NOTICEBOARD & EVENTS
// ==============================

model Notice {
  id          String  @id @default(uuid())
  title       String
  description String?
  driveUrl    String? // Optional link to an official PDF notice on Google Drive
  category    String // e.g., "Academic", "Exam", "Admission", "Holiday"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CampusEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  location    String? // e.g., "Auditorium", "Permanent Campus Ground"
  eventDate   DateTime // Admin specified date and time

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
